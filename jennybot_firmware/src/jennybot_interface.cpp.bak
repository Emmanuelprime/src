#include <jennybot_firmware/jennybot_interface.hpp>
#include <hardware_interface/types/hardware_interface_return_values.hpp>
#include <hardware_interface/types/hardware_interface_type_values.hpp>
#include <rclcpp/logging.hpp>
#include <sstream>
#include <iomanip>

namespace jennybot_firmware
{
    JennyBotInterface::JennyBotInterface()
    {

    }

    JennyBotInterface::~JennyBotInterface()
    {
        if(arduino_.IsOpen()){
            try{
                arduino_.Close();
            }
            catch(...){
                RCLCPP_FATAL_STREAM(rclcpp::get_logger("JennyBotInterface"), "Error closing serial port" << port_);
            }
        }
        
    }

    CallbackReturn JennyBotInterface::on_init(const hardware_interface::HardwareInfo & hardware_info){
        CallbackReturn result = hardware_interface::SystemInterface::on_init(hardware_info);
        if (result != CallbackReturn::SUCCESS) {
            return result;
        }
        
        // Get port parameter (required)
        try{
            port_ = info_.hardware_parameters["port"];
        }
        catch(const std::out_of_range & e){
            RCLCPP_FATAL(rclcpp::get_logger("JennyBotInterface"), "Serial Port parameter not found! Aborting initialization");
            return CallbackReturn::FAILURE;
        }
        
        // Get optional baud rate parameter
        try{
            baud_rate_ = std::stoi(info_.hardware_parameters.at("baud_rate"));
            RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "Using configured baud rate: %d", baud_rate_);
        }
        catch(const std::out_of_range & e){
            baud_rate_ = 115200;  // Default
            RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "Using default baud rate: %d", baud_rate_);
        }
        
        // Get optional timeout parameter
        try{
            timeout_seconds_ = std::stod(info_.hardware_parameters.at("timeout_seconds"));
            RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "Using configured timeout: %.2f seconds", timeout_seconds_);
        }
        catch(const std::out_of_range & e){
            timeout_seconds_ = DEFAULT_TIMEOUT;
            RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "Using default timeout: %.2f seconds", timeout_seconds_);
        }
        
        velocity_commands_.reserve(info_.joints.size());
        position_states_.reserve(info_.joints.size());
        velocity_states_.reserve(info_.joints.size());

        last_run_ = rclcpp::Clock().now();
        consecutive_read_errors_ = 0;
        
        return CallbackReturn::SUCCESS;
    }

    std::vector<hardware_interface::StateInterface> JennyBotInterface::export_state_interfaces(){
        std::vector<hardware_interface::StateInterface> state_interfaces;
        for (size_t i = 0; i < info_.joints.size(); i++) {
            state_interfaces.emplace_back(hardware_interface::StateInterface(info_.joints[i].name, hardware_interface::HW_IF_POSITION, &position_states_[i]));
            state_interfaces.emplace_back(hardware_interface::StateInterface(info_.joints[i].name, hardware_interface::HW_IF_VELOCITY, &velocity_states_[i]));
        }
        return state_interfaces;
        
    }
    
    std::vector<hardware_interface::CommandInterface> JennyBotInterface::export_command_interfaces(){
        std::vector<hardware_interface::CommandInterface> command_interfaces;
        for (size_t i = 0; i < info_.joints.size(); i++) {
            command_interfaces.emplace_back(hardware_interface::CommandInterface(info_.joints[i].name, hardware_interface::HW_IF_VELOCITY, &velocity_commands_[i]));
        }
        return command_interfaces;
    }

    CallbackReturn JennyBotInterface::on_activate(const rclcpp_lifecycle::State & previous_state){
        RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "Starting JennyBotInterface...");
        velocity_commands_ = {0.0, 0.0};
        position_states_ = {0.0, 0.0};
        velocity_states_ = {0.0, 0.0};
        try{
            arduino_.Open(port_);
            
            // Set baud rate based on configuration
            LibSerial::BaudRate baud_rate;
            switch(baud_rate_) {
                case 9600:   baud_rate = LibSerial::BaudRate::BAUD_9600; break;
                case 19200:  baud_rate = LibSerial::BaudRate::BAUD_19200; break;
                case 38400:  baud_rate = LibSerial::BaudRate::BAUD_38400; break;
                case 57600:  baud_rate = LibSerial::BaudRate::BAUD_57600; break;
                case 115200: baud_rate = LibSerial::BaudRate::BAUD_115200; break;
                default:
                    RCLCPP_WARN(rclcpp::get_logger("JennyBotInterface"), "Unsupported baud rate %d, using 115200", baud_rate_);
                    baud_rate = LibSerial::BaudRate::BAUD_115200;
            }
            arduino_.SetBaudRate(baud_rate);
            
            // Flush any stale data
            arduino_.FlushIOBuffers();
            
            last_successful_read_ = rclcpp::Clock().now();
            consecutive_read_errors_ = 0;
        }
        catch(const std::exception & e){
            RCLCPP_FATAL_STREAM(rclcpp::get_logger("JennyBotInterface"), "Error opening serial port: " << e.what());
            return CallbackReturn::FAILURE;
        }

        RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "JennyBotInterface started successfully! Ready to take commands.");

        return CallbackReturn::SUCCESS;
    }
    CallbackReturn JennyBotInterface::on_deactivate(const rclcpp_lifecycle::State & previous_state){
        RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "Stopping JennyBotInterface...");
        if(arduino_.IsOpen()){
            try{
                arduino_.Close();
            }
            catch(...){
                RCLCPP_FATAL_STREAM(rclcpp::get_logger("JennyBotInterface"), "Error closing serial port" << port_);
                return CallbackReturn::FAILURE;
            }
        }
        RCLCPP_INFO(rclcpp::get_logger("JennyBotInterface"), "JennyBotInterface stopped successfully!");
        return CallbackReturn::SUCCESS;
    }

    hardware_interface::return_type JennyBotInterface::read(const rclcpp::Time & time, const rclcpp::Duration & period){
        // Check for timeout
        if(checkTimeout(time)) {
            RCLCPP_ERROR(rclcpp::get_logger("JennyBotInterface"), 
                "Communication timeout! No data received for %.2f seconds", timeout_seconds_);
            
            // Attempt reconnection after too many errors
            if(consecutive_read_errors_++ > MAX_READ_ERRORS) {
                RCLCPP_WARN(rclcpp::get_logger("JennyBotInterface"), "Attempting to reconnect...");
                attemptReconnection();
            }
            return hardware_interface::return_type::ERROR;
        }
        
        if(arduino_.IsDataAvailable()){
            std::string message;
            auto dt = period.seconds();  // USE PERIOD PARAMETER, NOT CLOCK DIFFERENCE!
            
            try{
                arduino_.ReadLine(message, '\n', 100);  // 100ms timeout for ReadLine
                
                // Validate message before parsing
                if(!validateMessage(message)) {
                    RCLCPP_WARN(rclcpp::get_logger("JennyBotInterface"), "Invalid message received: %s", message.c_str());
                    consecutive_read_errors_++;
                    return hardware_interface::return_type::OK;  // Don't fail, just skip bad message
                }
                
                std::stringstream ss(message);
                std::string res;

                while(std::getline(ss, res, ',')){
                    // Safety check: ensure string is long enough
                    if(res.length() < 3) {
                        RCLCPP_WARN(rclcpp::get_logger("JennyBotInterface"), "Message segment too short: %s", res.c_str());
                        continue;
                    }
                    
                    int multiplier = (res[1] == 'p') ? 1 : -1;
                    double value = multiplier * std::stod(res.substr(2));
                    
                    // Sanity check: velocity should be reasonable (adjust limits as needed)
                    if(std::abs(value) > 100.0) {
                        RCLCPP_WARN(rclcpp::get_logger("JennyBotInterface"), 
                            "Unrealistic velocity value: %.2f, ignoring", value);
                        continue;
                    }
                    
                    if(res[0] == 'r')
                    {
                        velocity_states_[0] = value;
                        position_states_[0] += velocity_states_[0] * dt;
                    }
                    else if(res[0] == 'l')
                    {
                    velocity_states_[1] = value;
                        position_states_[1] += velocity_states_[1] * dt;
                    }
                }
                
                // Success! Reset error counter and update timestamp
                last_successful_read_ = time;
                consecutive_read_errors_ = 0;
            }
            catch(const std::exception & e){
                RCLCPP_ERROR_STREAM(rclcpp::get_logger("JennyBotInterface"), 
                    "Error parsing message: " << e.what() << " | Message: " << message);
                consecutive_read_errors_++;
                
                if(consecutive_read_errors_ > MAX_READ_ERRORS) {
                    return hardware_interface::return_type::ERROR;
                }
                return hardware_interface::return_type::OK;  // Continue despite parse error
            }
        }
        return hardware_interface::return_type::OK;
    }

    hardware_interface::return_type JennyBotInterface::write(const rclcpp::Time & time, const rclcpp::Duration & period){
        std::stringstream message_stream;
        char right_wheel_sign = velocity_commands_[0] >= 0 ? 'p' : 'n';
        char left_wheel_sign = velocity_commands_[1] >= 0 ? 'p' : 'n';
        std::string compensate_zero_right = "";
        std::string compensate_zero_left = "";
        if(std::abs(velocity_commands_[0]) < 10.0){
            compensate_zero_right = "0";
        }
        else {
            compensate_zero_right = "";
        }

        if(std::abs(velocity_commands_[1]) < 10.0){
            compensate_zero_left = "0";
        }
        else {
            compensate_zero_left = "";
        }

        message_stream << std::fixed << std::setprecision(2) << "r" << right_wheel_sign << compensate_zero_right << std::abs(velocity_commands_[0]) << ",l" << left_wheel_sign << compensate_zero_left << std::abs(velocity_commands_[1]) << ",";
        
        try{
            arduino_.Write(message_stream.str());
        }
        catch(const std::exception & e){
            RCLCPP_ERROR_STREAM(rclcpp::get_logger("JennyBotInterface"), "Error writing to serial port: " << e.what());
            return hardware_interface::return_type::ERROR;
        }
        return hardware_interface::return_type::OK;
    }
    
    // Helper method: Validate message format
    bool JennyBotInterface::validateMessage(const std::string& message) {
        if(message.empty()) return false;
        
        // Basic format check: should contain at least one comma
        if(message.find(',') == std::string::npos) return false;
        
        // Check for valid prefixes (r or l) and signs (p or n)
        std::stringstream ss(message);
        std::string segment;
        int valid_segments = 0;
        
        while(std::getline(ss, segment, ',')) {
            if(segment.length() < 3) continue;
            
            char prefix = segment[0];
            char sign = segment[1];
            
            if((prefix == 'r' || prefix == 'l') && (sign == 'p' || sign == 'n')) {
                valid_segments++;
            }
        }
        
        return valid_segments > 0;
    }
    
    // Helper method: Check for communication timeout
    bool JennyBotInterface::checkTimeout(const rclcpp::Time& current_time) {
        auto elapsed = (current_time - last_successful_read_).seconds();
        return elapsed > timeout_seconds_;
    }
    
    // Helper method: Attempt to reconnect to serial port
    void JennyBotInterface::attemptReconnection() {
        try {
            if(arduino_.IsOpen()) {
                arduino_.Close();\n            }\n            \n            RCLCPP_INFO(rclcpp::get_logger(\"JennyBotInterface\"), \"Reconnecting to %s...\", port_.c_str());\n            arduino_.Open(port_);\n            \n            LibSerial::BaudRate baud_rate;\n            switch(baud_rate_) {\n                case 9600:   baud_rate = LibSerial::BaudRate::BAUD_9600; break;\n                case 19200:  baud_rate = LibSerial::BaudRate::BAUD_19200; break;\n                case 38400:  baud_rate = LibSerial::BaudRate::BAUD_38400; break;\n                case 57600:  baud_rate = LibSerial::BaudRate::BAUD_57600; break;\n                case 115200: baud_rate = LibSerial::BaudRate::BAUD_115200; break;\n                default:     baud_rate = LibSerial::BaudRate::BAUD_115200;\n            }\n            arduino_.SetBaudRate(baud_rate);\n            arduino_.FlushIOBuffers();\n            \n            last_successful_read_ = rclcpp::Clock().now();\n            consecutive_read_errors_ = 0;\n            \n            RCLCPP_INFO(rclcpp::get_logger(\"JennyBotInterface\"), \"Reconnection successful!\");\n        }\n        catch(const std::exception & e) {\n            RCLCPP_ERROR_STREAM(rclcpp::get_logger(\"JennyBotInterface\"), \n                \"Reconnection failed: \" << e.what());\n        }\n    }

}

#include <pluginlib/class_list_macros.hpp>
PLUGINLIB_EXPORT_CLASS(jennybot_firmware::JennyBotInterface, hardware_interface::SystemInterface)